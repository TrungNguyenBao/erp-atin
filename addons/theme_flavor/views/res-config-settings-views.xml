<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_theme_flavor" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.theme.flavor</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Theme Flavor" string="Theme Flavor" name="theme_flavor">

                    <!-- Theme Style -->
                    <block title="Theme Style" name="tf_theme_style_setting">
                        <setting string="Visual Style" help="Choose between Flat Design and Aurora UI">
                            <field name="tf_theme_style" widget="radio"
                                   options="{'horizontal': true}"/>
                        </setting>
                    </block>

                    <!-- Menu Layout -->
                    <block title="Menu Layout" name="tf_menu_layout_setting">
                        <setting string="Menu Position" help="Horizontal top bar or vertical sidebar">
                            <field name="tf_menu_layout" widget="radio"
                                   options="{'horizontal': true}"/>
                        </setting>
                    </block>

                    <!-- Color Palette -->
                    <block title="Color Palette" name="tf_color_palette_setting">
                        <setting string="Color Preset" help="Choose a preset palette or customize colors">
                            <field name="tf_color_preset"/>
                        </setting>

                        <setting string="Brand Color"
                                 invisible="tf_color_preset != 'custom'">
                            <field name="tf_brand_color" widget="color"/>
                        </setting>
                        <setting string="Navigation Color"
                                 invisible="tf_color_preset != 'custom'">
                            <field name="tf_nav_color" widget="color"/>
                        </setting>
                        <setting string="Form Accent"
                                 invisible="tf_color_preset != 'custom'">
                            <field name="tf_accent_color" widget="color"/>
                        </setting>
                        <setting string="Button Primary"
                                 invisible="tf_color_preset != 'custom'">
                            <field name="tf_btn_primary_color" widget="color"/>
                        </setting>
                        <setting string="Button Secondary"
                                 invisible="tf_color_preset != 'custom'">
                            <field name="tf_btn_secondary_color" widget="color"/>
                        </setting>
                        <setting string="Button Success"
                                 invisible="tf_color_preset != 'custom'">
                            <field name="tf_btn_success_color" widget="color"/>
                        </setting>
                        <setting string="Button Danger"
                                 invisible="tf_color_preset != 'custom'">
                            <field name="tf_btn_danger_color" widget="color"/>
                        </setting>
                    </block>

                    <!-- Module Icons -->
                    <block title="Module Icons" name="tf_module_icons_setting">
                        <setting string="Custom Module Icons" help="Override default module icons">
                            <button name="%(theme_flavor.action_theme_flavor_icon)d"
                                    type="action" string="Configure Module Icons"
                                    class="btn-link" icon="fa-paint-brush"/>
                        </setting>
                    </block>

                </app>
            </xpath>
        </field>
    </record>
</odoo>
