<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="project_finance_report.FinanceDashboard">
        <div class="o_finance_dashboard">
            <div class="o_finance_header d-flex align-items-center justify-content-between p-3">
                <h2 class="mb-0">Project Financial Dashboard</h2>
                <button class="btn btn-primary" t-on-click="onRefresh">
                    <i class="fa fa-refresh"/> Refresh
                </button>
            </div>

            <!-- KPI Summary Cards -->
            <div class="o_finance_kpis d-flex flex-wrap gap-3 p-3">
                <div class="o_kpi_card card flex-fill" style="min-width: 200px;">
                    <div class="card-body text-center">
                        <h6 class="text-muted">Total Revenue</h6>
                        <h3 class="text-success" t-esc="formatCurrency(state.totals.revenue)"/>
                    </div>
                </div>
                <div class="o_kpi_card card flex-fill" style="min-width: 200px;">
                    <div class="card-body text-center">
                        <h6 class="text-muted">Total Cost</h6>
                        <h3 class="text-danger" t-esc="formatCurrency(state.totals.cost)"/>
                    </div>
                </div>
                <div class="o_kpi_card card flex-fill" style="min-width: 200px;">
                    <div class="card-body text-center">
                        <h6 class="text-muted">Gross Profit</h6>
                        <h3 t-attf-class="{{state.totals.gross_profit >= 0 ? 'text-success' : 'text-danger'}}"
                            t-esc="formatCurrency(state.totals.gross_profit)"/>
                    </div>
                </div>
                <div class="o_kpi_card card flex-fill" style="min-width: 200px;">
                    <div class="card-body text-center">
                        <h6 class="text-muted">Receivable</h6>
                        <h3 class="text-warning" t-esc="formatCurrency(state.totals.receivable)"/>
                    </div>
                </div>
                <div class="o_kpi_card card flex-fill" style="min-width: 200px;">
                    <div class="card-body text-center">
                        <h6 class="text-muted">Payable</h6>
                        <h3 class="text-info" t-esc="formatCurrency(state.totals.payable)"/>
                    </div>
                </div>
            </div>

            <!-- Charts Row -->
            <div class="o_finance_charts d-flex flex-wrap gap-3 p-3">
                <div class="card flex-fill" style="min-width: 45%;">
                    <div class="card-header">Revenue vs Cost by Project</div>
                    <div class="card-body">
                        <canvas t-ref="revenueChart" height="300"/>
                    </div>
                </div>
                <div class="card flex-fill" style="min-width: 45%;">
                    <div class="card-header">Receivable Aging</div>
                    <div class="card-body">
                        <canvas t-ref="agingChart" height="300"/>
                    </div>
                </div>
            </div>

            <!-- Project Table -->
            <div class="o_finance_table p-3">
                <div class="card">
                    <div class="card-header">Project Financial Summary</div>
                    <div class="card-body p-0">
                        <table class="table table-striped table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Project</th>
                                    <th class="text-end">Revenue</th>
                                    <th class="text-end">Cost</th>
                                    <th class="text-end">Profit</th>
                                    <th class="text-end">Margin</th>
                                    <th class="text-end">Receivable</th>
                                    <th class="text-end">Payable</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="state.projects" t-as="proj" t-key="proj.id">
                                    <tr>
                                        <td t-esc="proj.name"/>
                                        <td class="text-end" t-esc="formatCurrency(proj.revenue)"/>
                                        <td class="text-end" t-esc="formatCurrency(proj.cost)"/>
                                        <td class="text-end"
                                            t-attf-class="text-end {{proj.profit >= 0 ? 'text-success' : 'text-danger'}}"
                                            t-esc="formatCurrency(proj.profit)"/>
                                        <td class="text-end" t-esc="proj.margin + '%'"/>
                                        <td class="text-end text-warning"
                                            t-esc="formatCurrency(proj.receivable)"/>
                                        <td class="text-end text-info"
                                            t-esc="formatCurrency(proj.payable)"/>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
