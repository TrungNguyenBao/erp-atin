<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List view -->
    <record id="partner_balance_report_list" model="ir.ui.view">
        <field name="name">partner.balance.report.list</field>
        <field name="model">partner.balance.report</field>
        <field name="arch" type="xml">
            <list string="Partner Balance by Project" create="false" edit="false" delete="false">
                <field name="partner_id"/>
                <field name="balance_type"/>
                <field name="project_name"/>
                <field name="total_invoiced" sum="Total Invoiced"/>
                <field name="total_paid" sum="Total Paid"/>
                <field name="amount_due" sum="Total Due"
                       decoration-danger="amount_due &gt; 0"/>
                <field name="total_debit" sum="Total Debit"/>
                <field name="total_credit" sum="Total Credit"/>
                <field name="balance" sum="Balance"
                       decoration-success="balance &gt; 0"
                       decoration-danger="balance &lt; 0"/>
                <field name="invoice_count"/>
            </list>
        </field>
    </record>

    <!-- Pivot view -->
    <record id="partner_balance_report_pivot" model="ir.ui.view">
        <field name="name">partner.balance.report.pivot</field>
        <field name="model">partner.balance.report</field>
        <field name="arch" type="xml">
            <pivot string="Partner Balance">
                <field name="partner_id" type="row"/>
                <field name="project_name" type="row"/>
                <field name="total_invoiced" type="measure"/>
                <field name="total_paid" type="measure"/>
                <field name="amount_due" type="measure"/>
                <field name="balance" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph view -->
    <record id="partner_balance_report_graph" model="ir.ui.view">
        <field name="name">partner.balance.report.graph</field>
        <field name="model">partner.balance.report</field>
        <field name="arch" type="xml">
            <graph string="Partner Balance" type="bar" stacked="True">
                <field name="partner_id"/>
                <field name="amount_due" type="measure"/>
                <field name="total_paid" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Search view -->
    <record id="partner_balance_report_search" model="ir.ui.view">
        <field name="name">partner.balance.report.search</field>
        <field name="model">partner.balance.report</field>
        <field name="arch" type="xml">
            <search string="Partner Balance">
                <field name="partner_id"/>
                <field name="project_name"/>
                <filter name="receivable" string="Receivable (KH)"
                        domain="[('balance_type', '=', 'receivable')]"/>
                <filter name="payable" string="Payable (NCC)"
                        domain="[('balance_type', '=', 'payable')]"/>
                <filter name="has_due" string="Has Amount Due"
                        domain="[('amount_due', '&gt;', 0)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_partner" string="Partner"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_type" string="Type (KH/NCC)"
                            context="{'group_by': 'balance_type'}"/>
                    <filter name="group_project" string="Project"
                            context="{'group_by': 'project_name'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_partner_balance_all" model="ir.actions.act_window">
        <field name="name">Partner Balance by Project</field>
        <field name="res_model">partner.balance.report</field>
        <field name="view_mode">pivot,list,graph</field>
        <field name="search_view_id" ref="partner_balance_report_search"/>
        <field name="context">{'group_by': ['balance_type', 'partner_id']}</field>
    </record>

    <record id="action_receivable_balance" model="ir.actions.act_window">
        <field name="name">Customer Balance (Dư nợ KH)</field>
        <field name="res_model">partner.balance.report</field>
        <field name="view_mode">pivot,list,graph</field>
        <field name="domain">[('balance_type', '=', 'receivable')]</field>
        <field name="search_view_id" ref="partner_balance_report_search"/>
        <field name="context">{'group_by': ['partner_id', 'project_name']}</field>
    </record>

    <record id="action_payable_balance" model="ir.actions.act_window">
        <field name="name">Supplier Balance (Dư nợ NCC)</field>
        <field name="res_model">partner.balance.report</field>
        <field name="view_mode">pivot,list,graph</field>
        <field name="domain">[('balance_type', '=', 'payable')]</field>
        <field name="search_view_id" ref="partner_balance_report_search"/>
        <field name="context">{'group_by': ['partner_id', 'project_name']}</field>
    </record>
</odoo>
