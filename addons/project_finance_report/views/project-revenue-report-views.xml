<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree view -->
    <record id="revenue_report_tree" model="ir.ui.view">
        <field name="name">project.revenue.report.tree</field>
        <field name="model">project.revenue.report</field>
        <field name="arch" type="xml">
            <list string="Revenue by Project" create="false" edit="false" delete="false">
                <field name="project_id"/>
                <field name="partner_id"/>
                <field name="user_id" string="Salesperson"/>
                <field name="date_order"/>
                <field name="revenue" sum="Total Revenue"/>
                <field name="purchase_cost" sum="Total Cost"/>
                <field name="gross_profit" sum="Total Profit"
                       decoration-success="gross_profit &gt; 0"
                       decoration-danger="gross_profit &lt; 0"/>
                <field name="margin_pct" string="Margin %"/>
                <field name="invoiced" sum="Total Invoiced"/>
                <field name="paid" sum="Total Paid"/>
                <field name="residual" sum="Total Outstanding"
                       decoration-danger="residual &gt; 0"/>
            </list>
        </field>
    </record>

    <!-- Pivot view -->
    <record id="revenue_report_pivot" model="ir.ui.view">
        <field name="name">project.revenue.report.pivot</field>
        <field name="model">project.revenue.report</field>
        <field name="arch" type="xml">
            <pivot string="Revenue by Project">
                <field name="project_id" type="row"/>
                <field name="revenue" type="measure"/>
                <field name="purchase_cost" type="measure"/>
                <field name="gross_profit" type="measure"/>
                <field name="invoiced" type="measure"/>
                <field name="paid" type="measure"/>
                <field name="residual" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph view -->
    <record id="revenue_report_graph" model="ir.ui.view">
        <field name="name">project.revenue.report.graph</field>
        <field name="model">project.revenue.report</field>
        <field name="arch" type="xml">
            <graph string="Revenue by Project" type="bar">
                <field name="project_id"/>
                <field name="revenue" type="measure"/>
                <field name="purchase_cost" type="measure"/>
                <field name="gross_profit" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Search view -->
    <record id="revenue_report_search" model="ir.ui.view">
        <field name="name">project.revenue.report.search</field>
        <field name="model">project.revenue.report</field>
        <field name="arch" type="xml">
            <search string="Revenue Report">
                <field name="project_id"/>
                <field name="partner_id"/>
                <field name="user_id" string="Salesperson"/>
                <filter name="this_month" string="This Month"
                        domain="[('date_order', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%%Y-%%m-%%d')),
                                 ('date_order', '&lt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                <filter name="this_quarter" string="This Quarter"
                        domain="[('date_order', '&gt;=', (context_today() - relativedelta(months=(context_today().month - 1) %% 3, day=1)).strftime('%%Y-%%m-%%d')),
                                 ('date_order', '&lt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                <filter name="this_year" string="This Year"
                        domain="[('date_order', '&gt;=', (context_today().replace(month=1, day=1)).strftime('%%Y-%%m-%%d')),
                                 ('date_order', '&lt;=', context_today().strftime('%%Y-%%m-%%d'))]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_project" string="Project"
                            context="{'group_by': 'project_id'}"/>
                    <filter name="group_partner" string="Customer"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_user" string="Salesperson"
                            context="{'group_by': 'user_id'}"/>
                    <filter name="group_month" string="Month"
                            context="{'group_by': 'date_order:month'}"/>
                    <filter name="group_quarter" string="Quarter"
                            context="{'group_by': 'date_order:quarter'}"/>
                    <filter name="group_year" string="Year"
                            context="{'group_by': 'date_order:year'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_revenue_report" model="ir.actions.act_window">
        <field name="name">Revenue by Project</field>
        <field name="res_model">project.revenue.report</field>
        <field name="view_mode">pivot,list,graph</field>
        <field name="search_view_id" ref="revenue_report_search"/>
        <field name="context">{'group_by': ['project_id']}</field>
    </record>
</odoo>
