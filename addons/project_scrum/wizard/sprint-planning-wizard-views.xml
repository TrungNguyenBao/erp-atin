<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Sprint Planning Wizard Form -->
    <record id="sprint_planning_wizard_form" model="ir.ui.view">
        <field name="name">project.sprint.planning.wizard.form</field>
        <field name="model">project.sprint.planning.wizard</field>
        <field name="arch" type="xml">
            <form string="Sprint Planning">
                <group>
                    <group>
                        <field name="sprint_id" readonly="1"/>
                        <field name="project_id"/>
                    </group>
                    <group>
                        <field name="capacity_points"/>
                        <field name="selected_points"/>
                        <field name="remaining_capacity"
                               decoration-danger="is_over_capacity"
                               decoration-success="not is_over_capacity"/>
                        <field name="is_over_capacity" invisible="1"/>
                    </group>
                </group>
                <separator string="Select Backlog Tasks"/>
                <field name="backlog_task_ids">
                    <list>
                        <field name="priority" widget="priority"/>
                        <field name="name" string="Story"/>
                        <field name="story_points"/>
                        <field name="user_ids"
                               widget="many2many_avatar_user"/>
                        <field name="stage_id"/>
                    </list>
                </field>
                <div class="alert alert-warning" role="alert"
                     invisible="not is_over_capacity">
                    <strong>Over capacity!</strong>
                    Selected tasks exceed planned sprint capacity.
                </div>
                <footer>
                    <button name="action_assign" type="object"
                            string="Assign to Sprint" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Sprint Planning Action (opened from sprint form) -->
    <record id="action_sprint_planning_wizard" model="ir.actions.act_window">
        <field name="name">Sprint Planning</field>
        <field name="res_model">project.sprint.planning.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
