<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Ceremony Form View -->
    <record id="scrum_ceremony_view_form" model="ir.ui.view">
        <field name="name">scrum.ceremony.form</field>
        <field name="model">scrum.ceremony</field>
        <field name="arch" type="xml">
            <form string="Ceremony">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Sprint Planning — Sprint 5"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="ceremony_type"/>
                            <field name="sprint_id" options="{'no_create': True}"/>
                            <field name="project_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="duration" widget="float_time"/>
                        </group>
                    </group>
                    <group string="Attendees">
                        <field name="attendee_ids"
                               widget="many2many_avatar_user"
                               nolabel="1"
                               placeholder="Add attendees..."/>
                    </group>
                    <notebook>
                        <page string="Meeting Notes" name="notes">
                            <field name="notes"
                                   placeholder="Record key discussions, decisions, and outcomes..."/>
                        </page>
                        <page string="Action Items" name="actions">
                            <field name="action_items"
                                   placeholder="List concrete follow-up actions with owners..."/>
                        </page>
                        <page string="Retrospective" name="retrospective"
                              invisible="ceremony_type != 'retrospective'">
                            <group string="What Went Well">
                                <field name="went_well" nolabel="1"
                                       placeholder="Things the team should continue doing..."/>
                            </group>
                            <group string="To Improve">
                                <field name="to_improve" nolabel="1"
                                       placeholder="Things the team should change or stop doing..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Ceremony List View -->
    <record id="scrum_ceremony_view_list" model="ir.ui.view">
        <field name="name">scrum.ceremony.list</field>
        <field name="model">scrum.ceremony</field>
        <field name="arch" type="xml">
            <list string="Ceremonies" default_order="date desc">
                <field name="name"/>
                <field name="ceremony_type" widget="badge"
                       decoration-info="ceremony_type == 'planning'"
                       decoration-success="ceremony_type == 'review'"
                       decoration-warning="ceremony_type == 'retrospective'"
                       decoration-primary="ceremony_type == 'daily'"/>
                <field name="sprint_id"/>
                <field name="project_id"/>
                <field name="date"/>
                <field name="duration" widget="float_time"/>
                <field name="attendee_ids" widget="many2many_avatar_user"
                       optional="show"/>
            </list>
        </field>
    </record>

    <!-- Ceremony Calendar View -->
    <record id="scrum_ceremony_view_calendar" model="ir.ui.view">
        <field name="name">scrum.ceremony.calendar</field>
        <field name="model">scrum.ceremony</field>
        <field name="arch" type="xml">
            <calendar string="Ceremonies"
                      date_start="date"
                      date_stop="date"
                      color="ceremony_type"
                      mode="month">
                <field name="ceremony_type"/>
                <field name="sprint_id"/>
                <field name="attendee_ids"/>
            </calendar>
        </field>
    </record>

    <!-- Ceremony Search View -->
    <record id="scrum_ceremony_view_search" model="ir.ui.view">
        <field name="name">scrum.ceremony.search</field>
        <field name="model">scrum.ceremony</field>
        <field name="arch" type="xml">
            <search string="Ceremonies">
                <field name="name"/>
                <field name="sprint_id"/>
                <field name="project_id"/>
                <filter string="Planning" name="planning"
                        domain="[('ceremony_type', '=', 'planning')]"/>
                <filter string="Daily Standup" name="daily"
                        domain="[('ceremony_type', '=', 'daily')]"/>
                <filter string="Review" name="review"
                        domain="[('ceremony_type', '=', 'review')]"/>
                <filter string="Retrospective" name="retrospective"
                        domain="[('ceremony_type', '=', 'retrospective')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Sprint" name="group_sprint"
                            context="{'group_by': 'sprint_id'}"/>
                    <filter string="Type" name="group_type"
                            context="{'group_by': 'ceremony_type'}"/>
                    <filter string="Project" name="group_project"
                            context="{'group_by': 'project_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action: All Ceremonies -->
    <record id="action_view_all_ceremonies" model="ir.actions.act_window">
        <field name="name">Ceremonies</field>
        <field name="res_model">scrum.ceremony</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="context">{'search_default_group_sprint': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No ceremonies yet
            </p>
            <p>
                Record Sprint Planning, Daily Standups, Sprint Reviews, and Retrospectives.
            </p>
        </field>
    </record>

</odoo>
