<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit Project Form: add enable_scrum toggle + sprint stat button -->
    <record id="view_project_form_inherit_scrum" model="ir.ui.view">
        <field name="name">project.project.form.inherit.scrum</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <!-- Add project code after project name -->
            <xpath expr="//div[hasclass('oe_title')]" position="inside">
                <div class="d-flex gap-2 mb-2">
                    <label for="project_code" string="Mã dự án"/>
                    <field name="project_code" placeholder="VD: 2026_SCB_HH"/>
                </div>
            </xpath>

            <!-- Add methodology selector + standup digest after allow_milestones -->
            <xpath expr="//setting[@id='project_milestone_setting']" position="after">
                <setting class="col-lg-12" id="project_methodology_setting"
                         help="Choose project management methodology"
                         groups="project_scrum.group_project_scrum">
                    <field name="methodology" widget="radio"/>
                </setting>
                <setting class="col-lg-12" id="project_standup_digest_setting"
                         help="Send daily sprint status email to project followers"
                         groups="project_scrum.group_project_scrum">
                    <field name="enable_standup_digest"
                           invisible="methodology != 'scrum'"/>
                </setting>
                <setting class="col-lg-12" id="project_wip_limit_setting"
                         help="Maximum tasks per column on Sprint Board (0 = no limit)"
                         groups="project_scrum.group_project_scrum">
                    <field name="wip_limit"
                           invisible="methodology != 'scrum'"/>
                </setting>
            </xpath>
            <!-- Add sprint count stat button in button_box -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" type="object"
                        name="action_view_project_sprints"
                        icon="fa-refresh"
                        invisible="methodology != 'scrum'"
                        groups="project_scrum.group_project_scrum">
                    <field name="sprint_count" string="Sprints"
                           widget="statinfo"/>
                </button>
                <button class="oe_stat_button" type="object"
                        name="action_print_velocity_report"
                        icon="fa-line-chart"
                        invisible="methodology != 'scrum'"
                        groups="project_scrum.group_project_scrum"
                        string="Velocity PDF"/>

            </xpath>
        </field>
    </record>

    <!-- Inherit Project Settings (res.config.settings): add Scrum toggle -->
    <record id="res_config_settings_view_form_inherit_scrum" model="ir.ui.view">
        <field name="name">res.config.settings.form.inherit.scrum</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="project.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='project_milestone']" position="after">
                <setting id="project_scrum"
                         help="Enable sprints, story points, and velocity tracking">
                    <field name="group_project_scrum"/>
                </setting>
            </xpath>
        </field>
    </record>

</odoo>
