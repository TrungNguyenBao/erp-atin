<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Sprint Form View -->
    <record id="project_sprint_view_form" model="ir.ui.view">
        <field name="name">project.sprint.form</field>
        <field name="model">project.sprint</field>
        <field name="arch" type="xml">
            <form string="Sprint">
                <header>
                    <button name="action_plan_sprint" type="object"
                            string="Plan Sprint"
                            invisible="state != 'draft'"/>
                    <button name="action_start_sprint" type="object"
                            string="Start Sprint" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_close_sprint" type="object"
                            string="Close Sprint" class="oe_highlight"
                            invisible="state != 'active'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_view_tasks" icon="fa-tasks">
                            <field name="task_count" string="Tasks"
                                   widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Sprint 1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"
                                   options="{'no_create': True}"
                                   readonly="state != 'draft'"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group>
                            <field name="capacity_points"/>
                            <field name="committed_points"/>
                            <field name="completed_points"/>
                            <field name="remaining_points"/>
                            <field name="velocity"
                                   invisible="state != 'closed'"/>
                        </group>
                    </group>
                    <group string="Sprint Goal">
                        <field name="goal" nolabel="1"
                               placeholder="What is the team committing to deliver this sprint?"/>
                    </group>
                    <notebook>
                        <page string="Tasks" name="tasks">
                            <field name="task_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="story_points"/>
                                    <field name="user_ids"
                                           widget="many2many_avatar_user"/>
                                    <field name="stage_id"/>
                                    <field name="state"
                                           widget="project_task_state_selection"/>
                                </list>
                            </field>
                        </page>
                        <page string="Review" name="review"
                              invisible="state == 'draft'">
                            <group>
                                <field name="review_date"/>
                            </group>
                            <group string="Sprint Review Notes">
                                <field name="review_notes" nolabel="1"
                                       placeholder="Summarize completed work and stakeholder feedback..."/>
                            </group>
                        </page>
                        <page string="Retrospective" name="retrospective"
                              invisible="state != 'closed'">
                            <group>
                                <field name="retro_date"/>
                            </group>
                            <group string="What Went Well">
                                <field name="retro_went_well" nolabel="1"
                                       placeholder="List things that worked well..."/>
                            </group>
                            <group string="What Could Improve">
                                <field name="retro_went_wrong" nolabel="1"
                                       placeholder="List things that need improvement..."/>
                            </group>
                            <group string="Action Items">
                                <field name="retro_action_items" nolabel="1"
                                       placeholder="List concrete actions for next sprint..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Sprint List View -->
    <record id="project_sprint_view_list" model="ir.ui.view">
        <field name="name">project.sprint.list</field>
        <field name="model">project.sprint</field>
        <field name="arch" type="xml">
            <list string="Sprints"
                  decoration-info="state == 'active'"
                  decoration-muted="state == 'closed'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'active'"
                       decoration-success="state == 'closed'"
                       decoration-warning="state == 'draft'"/>
                <field name="capacity_points"/>
                <field name="committed_points"/>
                <field name="completed_points"/>
                <field name="velocity"/>
            </list>
        </field>
    </record>

    <!-- Sprint Kanban View -->
    <record id="project_sprint_view_kanban" model="ir.ui.view">
        <field name="name">project.sprint.kanban</field>
        <field name="model">project.sprint</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state">
                <field name="name"/>
                <field name="state"/>
                <field name="project_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="capacity_points"/>
                <field name="committed_points"/>
                <field name="completed_points"/>
                <field name="task_count"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between">
                            <strong><field name="name"/></strong>
                            <field name="state" widget="label_selection"
                                   options="{'classes': {'draft': 'warning', 'active': 'info', 'closed': 'success'}}"/>
                        </div>
                        <field name="project_id"/>
                        <div class="text-muted small">
                            <field name="start_date"/> — <field name="end_date"/>
                        </div>
                        <div class="mt-1">
                            <span class="badge text-bg-primary me-1">
                                <field name="task_count"/> tasks
                            </span>
                            <span class="badge text-bg-secondary">
                                <field name="committed_points"/>/<field name="capacity_points"/> pts
                            </span>
                        </div>
                        <field name="completed_points" widget="progressbar"
                               options="{'max_value': 'capacity_points'}"/>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Sprint Search View -->
    <record id="project_sprint_view_search" model="ir.ui.view">
        <field name="name">project.sprint.search</field>
        <field name="model">project.sprint</field>
        <field name="arch" type="xml">
            <search string="Search Sprints">
                <field name="name"/>
                <field name="project_id"/>
                <filter string="Draft" name="draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Active" name="active_sprint"
                        domain="[('state', '=', 'active')]"/>
                <filter string="Closed" name="closed"
                        domain="[('state', '=', 'closed')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Project" name="group_project"
                            context="{'group_by': 'project_id'}"/>
                    <filter string="State" name="group_state"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Sprint Action: view all sprints -->
    <record id="action_view_all_sprints" model="ir.actions.act_window">
        <field name="name">Sprints</field>
        <field name="res_model">project.sprint</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="project_sprint_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first sprint
            </p>
            <p>
                Sprints are time-boxed iterations where your team commits
                to delivering a set of user stories.
            </p>
        </field>
    </record>

    <!-- Sprint: action to view tasks (stat button) -->
    <record id="action_view_sprint_tasks" model="ir.actions.act_window">
        <field name="name">Sprint Tasks</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('sprint_id', '=', active_id)]</field>
        <field name="context">{
            'default_sprint_id': active_id,
            'search_default_sprint_id': active_id,
        }</field>
    </record>

</odoo>
