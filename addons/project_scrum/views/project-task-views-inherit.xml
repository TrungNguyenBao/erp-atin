<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit Task Form: add story_points + sprint_id -->
    <record id="view_task_form_inherit_scrum" model="ir.ui.view">
        <field name="name">project.task.form.inherit.scrum</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <!-- Hidden related field for conditional visibility -->
            <xpath expr="//field[@name='allocated_hours']" position="before">
                <field name="enable_scrum" invisible="1"/>
                <field name="story_points"
                       invisible="not project_id or not enable_scrum"
                       groups="project_scrum.group_project_scrum"/>
            </xpath>
            <!-- Add sprint_id after milestone_id -->
            <xpath expr="//field[@name='milestone_id']" position="after">
                <field name="sprint_id"
                       invisible="not project_id or not enable_scrum"
                       groups="project_scrum.group_project_scrum"
                       options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit Task Search: add sprint filter + group-by -->
    <record id="view_task_search_inherit_scrum" model="ir.ui.view">
        <field name="name">project.task.search.inherit.scrum</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_search_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='milestone_id']" position="after">
                <field name="sprint_id"
                       groups="project_scrum.group_project_scrum"/>
            </xpath>
            <xpath expr="//filter[@name='milestone']" position="after">
                <filter string="Sprint" name="sprint"
                        context="{'group_by': 'sprint_id'}"
                        groups="project_scrum.group_project_scrum"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit Task List: add story_points column -->
    <record id="view_task_list_inherit_scrum" model="ir.ui.view">
        <field name="name">project.task.list.inherit.scrum</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_tree2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='milestone_id']" position="after">
                <field name="sprint_id" optional="hide"
                       groups="project_scrum.group_project_scrum"/>
                <field name="story_points" optional="hide"
                       groups="project_scrum.group_project_scrum"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit Task Kanban: add story points badge -->
    <record id="view_task_kanban_inherit_scrum" model="ir.ui.view">
        <field name="name">project.task.kanban.inherit.scrum</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tag_ids']" position="before">
                <span t-if="record.story_points.raw_value"
                      class="badge text-bg-info me-1"
                      groups="project_scrum.group_project_scrum">
                    <field name="story_points"/> SP
                </span>
            </xpath>
        </field>
    </record>

</odoo>
