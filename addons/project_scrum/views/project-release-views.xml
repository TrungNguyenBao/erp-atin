<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Release Form -->
    <record id="project_release_view_form" model="ir.ui.view">
        <field name="name">project.release.form</field>
        <field name="model">project.release</field>
        <field name="arch" type="xml">
            <form string="Release">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="planning,in_progress,released"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. v2.0"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" options="{'no_create': True}"/>
                            <field name="target_date"/>
                        </group>
                        <group>
                            <field name="sprint_count"/>
                            <field name="total_points"/>
                            <field name="completed_points"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Sprints" name="sprints">
                            <field name="sprint_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="state" widget="badge"/>
                                    <field name="committed_points"/>
                                    <field name="velocity"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Release List -->
    <record id="project_release_view_list" model="ir.ui.view">
        <field name="name">project.release.list</field>
        <field name="model">project.release</field>
        <field name="arch" type="xml">
            <list string="Releases"
                  decoration-success="state == 'released'"
                  decoration-info="state == 'in_progress'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="target_date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'released'"
                       decoration-info="state == 'in_progress'"
                       decoration-warning="state == 'planning'"/>
                <field name="sprint_count"/>
                <field name="total_points"/>
                <field name="completed_points"/>
            </list>
        </field>
    </record>

    <!-- Release Action -->
    <record id="action_view_all_releases" model="ir.actions.act_window">
        <field name="name">Releases</field>
        <field name="res_model">project.release</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first release
            </p>
            <p>Releases group sprints into deliverable milestones.</p>
        </field>
    </record>

</odoo>
