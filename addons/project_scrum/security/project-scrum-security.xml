<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Hidden feature group: toggled by enable_scrum on project -->
    <record id="group_project_scrum" model="res.groups">
        <field name="name">Use Scrum</field>
        <field name="category_id" ref="base.module_category_hidden"/>
    </record>

    <!-- Scrum role groups (category: Project) -->
    <record id="group_scrum_user" model="res.groups">
        <field name="name">Scrum User</field>
        <field name="category_id" ref="base.module_category_services_project"/>
        <field name="implied_ids" eval="[(4, ref('project.group_project_user'))]"/>
        <field name="comment">View sprints, tasks, ceremonies. Assign tasks. Update story points and task status.</field>
    </record>

    <record id="group_scrum_master" model="res.groups">
        <field name="name">Scrum Master</field>
        <field name="category_id" ref="base.module_category_services_project"/>
        <field name="implied_ids" eval="[(4, ref('group_scrum_user'))]"/>
        <field name="comment">Create and manage sprints, ceremonies, sprint board. Move tasks between sprints.</field>
    </record>

    <record id="group_product_owner" model="res.groups">
        <field name="name">Product Owner</field>
        <field name="category_id" ref="base.module_category_services_project"/>
        <field name="implied_ids" eval="[(4, ref('group_scrum_master'))]"/>
        <field name="comment">Manage product backlog, create and prioritize epics, accept/reject user stories.</field>
    </record>

<data noupdate="1">

    <!-- Sprint: multi-company isolation -->
    <record model="ir.rule" id="sprint_comp_rule">
        <field name="name">Sprint: multi-company</field>
        <field name="model_id" ref="model_project_sprint"/>
        <field name="domain_force">[('company_id', 'in', company_ids + [False])]</field>
    </record>

    <!-- Sprint: employees must follow project for follower-only projects -->
    <record model="ir.rule" id="sprint_visibility_rule">
        <field name="name">Sprint: follow project privacy</field>
        <field name="model_id" ref="model_project_sprint"/>
        <field name="domain_force">['|',
            ('project_id.privacy_visibility', '!=', 'followers'),
            ('project_id.message_partner_ids', 'in', [user.partner_id.id])
        ]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Sprint: managers see all -->
    <record model="ir.rule" id="sprint_manager_rule">
        <field name="name">Sprint: project manager: see all</field>
        <field name="model_id" ref="model_project_sprint"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('project.group_project_manager'))]"/>
    </record>

    <!-- Epic: multi-company -->
    <record model="ir.rule" id="epic_comp_rule">
        <field name="name">Epic: multi-company</field>
        <field name="model_id" ref="model_project_epic"/>
        <field name="domain_force">[('company_id', 'in', company_ids + [False])]</field>
    </record>

    <!-- Epic: follow project privacy -->
    <record model="ir.rule" id="epic_visibility_rule">
        <field name="name">Epic: follow project privacy</field>
        <field name="model_id" ref="model_project_epic"/>
        <field name="domain_force">['|',
            ('project_id.privacy_visibility', '!=', 'followers'),
            ('project_id.message_partner_ids', 'in', [user.partner_id.id])
        ]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Epic: managers see all -->
    <record model="ir.rule" id="epic_manager_rule">
        <field name="name">Epic: project manager: see all</field>
        <field name="model_id" ref="model_project_epic"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('project.group_project_manager'))]"/>
    </record>

    <!-- Release: multi-company -->
    <record model="ir.rule" id="release_comp_rule">
        <field name="name">Release: multi-company</field>
        <field name="model_id" ref="model_project_release"/>
        <field name="domain_force">[('company_id', 'in', company_ids + [False])]</field>
    </record>

    <!-- Release: managers see all -->
    <record model="ir.rule" id="release_manager_rule">
        <field name="name">Release: project manager: see all</field>
        <field name="model_id" ref="model_project_release"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('project.group_project_manager'))]"/>
    </record>

    <!-- Ceremony: multi-company isolation -->
    <record model="ir.rule" id="ceremony_comp_rule">
        <field name="name">Ceremony: multi-company</field>
        <field name="model_id" ref="model_scrum_ceremony"/>
        <field name="domain_force">[('company_id', 'in', company_ids + [False])]</field>
    </record>

    <!-- Ceremony: follow project privacy -->
    <record model="ir.rule" id="ceremony_visibility_rule">
        <field name="name">Ceremony: follow project privacy</field>
        <field name="model_id" ref="model_scrum_ceremony"/>
        <field name="domain_force">['|',
            ('project_id.privacy_visibility', '!=', 'followers'),
            ('project_id.message_partner_ids', 'in', [user.partner_id.id])
        ]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Ceremony: managers see all -->
    <record model="ir.rule" id="ceremony_manager_rule">
        <field name="name">Ceremony: project manager: see all</field>
        <field name="model_id" ref="model_scrum_ceremony"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('project.group_project_manager'))]"/>
    </record>

</data>

</odoo>
